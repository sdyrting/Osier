library(devtools)
usethis::use_readme_rmd()
library(RprojOSR)
fert_data <- aus_f_asfr_2011
head(fert_data)
fert_name <- 'AUS-F_FERT_2011'
osr.CreateObj(fert_name,'fertility',list('Population','Date','BuildMethod'),list('AUS-P/AUS-F',20111231,'CONSTAT_FERT'),'FertilityRates',as.matrix(names(fert_data)),as.matrix(fert_data))
osr.TotalFertRate(fert_name)
osr.CreateObj(fert_name,'fertility',list('Population','Date','BuildMethod'),list('AUS-P/AUS-F',20111231,'CONSTANT_FERT'),'FertilityRates',as.matrix(names(fert_data)),as.matrix(fert_data))
osr.TotalFertRate(fert_name)
osr.SaveObjs(fert_name,'fertility','./FertObjs.txt')
osr.LoadObjs(,,'./FertObjs.txt')
